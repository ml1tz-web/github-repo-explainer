{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // Bundler resolution lets us consume @repo/shared's extensionless internal
    // imports cleanly. We still emit ESM via tsup; tsx watch handles dev. The
    // strict NodeNext is the right answer for a pure-Node project; since we
    // bundle, Bundler matches reality.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}

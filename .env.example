# =============================================================================
# GitHub Repo Explainer — environment variables
# Copy to `.env` for local dev. Each app reads only the vars it needs.
# =============================================================================

# ---- Shared ----
NODE_ENV=development

# ---- Database (consumed by api + prisma) ----
# Inside docker-compose, host is `postgres`. For host-machine dev, use localhost.
POSTGRES_USER=explainer
POSTGRES_PASSWORD=explainer_dev_password
POSTGRES_DB=explainer
DATABASE_URL=postgresql://explainer:explainer_dev_password@localhost:5432/explainer?schema=public

# ---- API ----
API_PORT=4000
API_LOG_LEVEL=info
# CORS origin for the web app
WEB_ORIGIN=http://localhost:3000
# Working directory for temporary git clones (auto-cleaned after analysis)
CLONE_TMP_DIR=./tmp/clones
# Hard caps to keep clones bounded
CLONE_MAX_REPO_SIZE_MB=200
CLONE_TIMEOUT_MS=60000

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Web ----
WEB_PORT=3000
# Public URL the browser uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:4000
